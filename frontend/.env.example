# 前端環境變數樣板 —— 本機開發複製成 frontend/.env.local。

# 後端公開 URL：瀏覽器端（client bundle）使用，build-time 烘入。
# 換 host 需重新 build 前端 image。
NEXT_PUBLIC_API_URL=http://localhost:8000

# 後端內網 URL：server component（serverFetch）使用，runtime 讀取、不烘進 bundle。
# 本機開發可省略（會退回 NEXT_PUBLIC_API_URL）；docker-compose 設為 http://backend:8000。
# API_INTERNAL_URL=http://localhost:8000
