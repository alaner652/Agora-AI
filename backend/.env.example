# 後端環境變數樣板 —— 複製成 backend/.env 後填入實值。

# ── LLM（系統預設模型；使用者未在設定頁自訂時採用）──────────────
LLM_API_KEY=sk-...
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3.1-flash-lite

# ── 免費伺服器 LLM 額度（只作用在「沒帶自己金鑰」的使用者）──────
# 每人每日上限與全站每日總量上限（以「每則新訊息」計），超過就引導使用者
# 改用自己的 AI 金鑰。純 BYOK 模式：不填 LLM_API_KEY，或把
# FREE_DAILY_PER_USER 設為 0 —— 沒設金鑰的人會收到友善提示而非 raw 401。
FREE_DAILY_PER_USER=20
FREE_DAILY_GLOBAL=500

# ── 安全 ─────────────────────────────────────────────────────
# 加密使用者設定（含其自訂 API key）的金鑰。必須設定且「長期固定」——
# 一旦更換，既有已加密的使用者設定將無法解開。
# 產生：python -c "import secrets; print(secrets.token_urlsafe(32))"
SETTINGS_ENCRYPT_KEY=

# ── 對外 CORS：允許的前端來源（逗號分隔）──────────────────────
# 同源（Caddy 反向代理）部署下「不需要」CORS，可留預設或忽略。
# 僅在「前端直連後端、跨來源」時才需設成前端公開來源，例如 http://<你的IP>:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# ── 學校入口（可選，預設 https://siw.tpcu.edu.tw）─────────────
# SCHOOL_BASE_URL=https://siw.tpcu.edu.tw

# ── 伺服器綁定（容器內預設即可，通常不需改）──────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

SUMMARY_WEBHOOK_URL= # 可選：設定後每次對話結束會 POST 對話摘要到此 URL，供外部系統使用。